# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# VITE_GOOGLE_MAPS_API_KEY: Required for Google Maps JavaScript API.
# Get one from https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_MAPS_API_KEY="AIzaSyBoD6PHm8szopZ1LZu_Vwf3LUC1R2RD3QE"
